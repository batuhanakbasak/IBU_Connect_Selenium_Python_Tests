# Base website and API
TARGET_BASE_URL=https://batuhanakbasak.com
TARGET_API_BASE_URL=https://api.batuhanakbasak.com/api

# Roles to include: student, organizer, admin
ENABLED_ROLES=student,organizer,admin

# Format: usersxduration_seconds,usersxduration_seconds
LOAD_STAGES=2x15,5x20,10x30

# Safety and pacing
REQUEST_TIMEOUT_SECONDS=15
REQUEST_DELAY_SECONDS=0.25
HIGH_STRESS_WARNING_USERS=25
HARD_CONCURRENCY_CAP=50
ALLOW_HIGH_STRESS=false
VERIFY_TLS=true

# Flow toggles
INCLUDE_LOGIN_PAGE_GET=true
INCLUDE_DASHBOARD_REQUEST=false
DASHBOARD_REQUEST_MODE=off
LOAD_TEST_USER_AGENT=IBU-Auth-Load-Toolkit/1.0

# Credentials
STUDENT_EMAIL=
STUDENT_PASSWORD=
ORGANIZER_EMAIL=
ORGANIZER_PASSWORD=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional dashboard paths
STUDENT_DASHBOARD_PAGE_PATH=/student/dashboard.html
ORGANIZER_DASHBOARD_PAGE_PATH=/organizer/dashboard.html
ADMIN_DASHBOARD_PAGE_PATH=/admin/dashboard.html

# Optional authenticated API endpoints after login
STUDENT_DASHBOARD_API_PATH=
ORGANIZER_DASHBOARD_API_PATH=
ADMIN_DASHBOARD_API_PATH=
